# Porta local. No Railway, nao defina PORT; ele injeta automaticamente.
WPP_PORT=21465

# Nivel de log: error, warn, info, debug ou silly.
WPP_LOG_LEVEL=info

# No Railway, prefira logs no console. Arquivo de log aumenta escrita em disco.
WPP_LOG_TO_FILE=false

# Inicia automaticamente as sessoes salvas quando o servidor sobe.
# No Railway, deixe false ate confirmar que login/codigo e volume estao OK.
WPP_START_ALL_SESSION=false

# Onde salvar tokens das sessoes.
# file = salva em arquivos; no Railway use um Volume montado em /data.
WPP_TOKEN_STORE_TYPE=file
WPP_TOKENS_DIR=/data/tokens
WPP_CUSTOM_USER_DATA_DIR=/data/userDataDir/

# Tempo para aguardar o WhatsApp Web ficar pronto antes de registrar listeners.
WPP_CONNECT_CHECK_RETRIES=36
WPP_CONNECT_CHECK_DELAY_MS=5000

# Railway: evita timeout de 60s antes do envio.
WPP_VALIDATE_NUMBER_STATUS=false
WPP_VERIFY_CONNECTED_BEFORE_SEND=false
WPP_CONNECTION_CHECK_TIMEOUT_MS=15000
WPP_NUMBER_STATUS_TIMEOUT_MS=12000
WPP_SEND_MESSAGE_TIMEOUT_MS=35000
WPP_PUPPETEER_PROTOCOL_TIMEOUT_MS=120000

# Alertas do bot para HTTP/API: abortos, 5xx e requisicoes lentas.
WPP_HTTP_ALERTS_ENABLED=true
WPP_HTTP_ALERT_4XX=false
WPP_HTTP_SLOW_MS=55000

# Limpa processos/locks antigos do Chromium usando o mesmo perfil da sessao.
WPP_KILL_STALE_CHROMIUM=true

# Opcional: webhook para receber eventos do WhatsApp.
# WPP_WEBHOOK_URL=https://seu-site.com/webhook

# Opcional: Telegram para receber QR Code e alertas.
# TELEGRAM_BOT_TOKEN=seu_token_do_bot
# TELEGRAM_CHAT_ID=seu_chat_id

# Opcional: monitor de reconexao.
MONITOR_MAX_RETRIES=5
MONITOR_PING_INTERVAL_MS=120000
MONITOR_PING_TIMEOUT_MS=20000
MONITOR_RETRY_BACKOFF_MS=30000
# Reinicia o Chromium apos falhas consecutivas do watchdog.
MONITOR_FAILURE_THRESHOLD=2
